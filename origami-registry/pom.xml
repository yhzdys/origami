<?xml version="1.0" encoding="UTF-8"?>
<project xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://maven.apache.org/POM/4.0.0"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>com.yhzdys.origami</groupId>
        <artifactId>origami-parent</artifactId>
        <version>1.0.0</version>
    </parent>
    <artifactId>origami-registry</artifactId>
    <version>${parent.version}</version>
    <packaging>pom</packaging>

    <modules>
        <module>origami-registry-adapter</module>
        <module>origami-registry-common</module>
        <module>origami-registry-eureka</module>
        <module>origami-registry-nacos</module>
    </modules>

    <dependencies>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <configuration>
                    <source>${java.version}</source>
                    <target>${java.version}</target>
                    <encoding>${project.build.encoding}</encoding>
                </configuration>
            </plugin>
        </plugins>
